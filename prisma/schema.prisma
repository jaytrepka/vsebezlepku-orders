generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  emailDate   DateTime
  rawEmail    String?
  totalPrice  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]
}

model OrderItem {
  id          String        @id @default(cuid())
  orderId     String
  productName String
  quantity    Int
  unitPrice   String?
  productUrl  String?
  productCode String?
  labelId     String?
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  label       ProductLabel? @relation(fields: [labelId], references: [id])
}

model ProductLabel {
  id              String      @id @default(cuid())
  productName     String      
  language        String      @default("cs") // cs = Czech, pl = Polish, sk = Slovak
  nazev           String      // Display name (e.g., PISTÁCIOVÉ DONUTY (90g))
  slozeni         String      // Ingredients with allergens marked
  nutricniHodnoty String      // Nutrition facts
  skladovani      String?     // Storage instructions (optional)
  vyrobce         String      // Manufacturer
  verified        Boolean     @default(false) // Whether the label has been verified as correct
  hasFactoryLabel Boolean     @default(false) // Product already has label from manufacturer, no need to print
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  orderItems      OrderItem[]

  @@unique([productName, language])
}

model StockProduct {
  id          String           @id @default(cuid())
  productName String           @unique
  code        String?
  totalCount  Int              @default(0)
  expirations ExpirationDate[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ExpirationDate {
  id                 String       @id @default(cuid())
  stockProductId     String
  expirationDate     DateTime
  count              Int
  neplytvatConfirmed Boolean      @default(false)
  stockProduct       StockProduct @relation(fields: [stockProductId], references: [id], onDelete: Cascade)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model BlacklistedCustomer {
  id        String   @id @default(cuid())
  name      String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id        String    @id @default(cuid())
  title     String
  priority  String    @default("medium") // low, medium, high
  deadline  DateTime?
  done      Boolean   @default(false)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Fair {
  id           String            @id @default(cuid())
  name         String
  active       Boolean           @default(true)
  products     FairProduct[]
  transactions FairTransaction[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model FairProduct {
  id              String                @id @default(cuid())
  fairId          String
  productName     String
  price           Float
  totalCount      Int
  soldCount       Int                   @default(0)
  sortOrder       Int                   @default(0)
  fair            Fair                  @relation(fields: [fairId], references: [id], onDelete: Cascade)
  transactionItems FairTransactionItem[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model FairTransaction {
  id         String                @id @default(cuid())
  fairId     String
  totalPrice Float
  items      FairTransactionItem[]
  fair       Fair                  @relation(fields: [fairId], references: [id], onDelete: Cascade)
  createdAt  DateTime              @default(now())
}

model FairTransactionItem {
  id            String          @id @default(cuid())
  transactionId String
  fairProductId String
  quantity      Int
  unitPrice     Float
  transaction   FairTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  fairProduct   FairProduct     @relation(fields: [fairProductId], references: [id], onDelete: Cascade)
}
